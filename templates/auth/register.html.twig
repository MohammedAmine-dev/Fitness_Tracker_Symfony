{% extends 'base.html.twig' %}

{% block title %}FitTrack | Create Account{% endblock %}

{% block meta_description %}Create your FitTrack account and start tracking your fitness goals today.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        <a href="{{ path('app_login') }}" class="auth-logo">
            <div class="logo-icon">FT</div>
            <div class="logo-text">Fit<span>Track</span></div>
        </a>

        <h1 class="auth-heading">Create your account</h1>
        <p class="auth-subheading">Start tracking your fitness journey today</p>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success" role="alert">{{ message }}</div>
        {% endfor %}

        {% if form_errors(form) is not empty %}
            <div class="alert alert-error" role="alert">
                {{ form_errors(form) }}
            </div>
        {% endif %}

        {{ form_start(form, {
            'attr': {'id': 'registration-form', 'novalidate': 'novalidate'}
        }) }}
            <div class="form-group">
                {{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-input', 'placeholder': 'Full name'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-input', 'placeholder': 'you@example.com'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-input', 'placeholder': 'Create a password'}}) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-input', 'placeholder': 'Confirm your password'}}) }}
                {{ form_errors(form.plainPassword.second) }}
            </div>

            <button id="register-submit" type="submit" class="btn btn-primary btn-full">
                Register
            </button>
        {{ form_end(form) }}

        <p class="auth-footer">
            Already have an account?
            <a href="{{ path('app_login') }}">Login here</a>
        </p>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}My Progress – FitTrack{% endblock %}

{% block importmap %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary:         #3B82F6;
            --primary-dark:    #2563EB;
            --primary-light:   #93C5FD;
            --primary-bg:      #EFF6FF;
            --accent-green:    #10B981;
            --accent-green-bg: #ECFDF5;
            --accent-orange:   #F59E0B;
            --accent-orange-bg:#FFFBEB;
            --accent-purple:   #8B5CF6;
            --accent-purple-bg:#F5F3FF;
            --gray-50:  #F9FAFB;
            --gray-100: #F3F4F6;
            --gray-200: #E5E7EB;
            --gray-400: #9CA3AF;
            --gray-600: #4B5563;
            --gray-700: #374151;
            --gray-800: #1F2937;
        }

        body { background: var(--gray-50); color: var(--gray-800); }

        .page-header {
            background: linear-gradient(135deg, var(--accent-purple) 0%, #6D28D9 100%);
            color: #fff;
            padding: 2.5rem 0 2rem;
            margin-bottom: 2rem;
        }
        .page-header h1 { font-size: 2rem; font-weight: 700; margin: 0; }
        .page-header p  { opacity: .85; margin: .4rem 0 0; }

        .card {
            background: #fff;
            border-radius: 1rem;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
            padding: 1.75rem;
            margin-bottom: 1.5rem;
        }
        .card-title { font-size: 1rem; font-weight: 600; color: var(--gray-700); margin-bottom: 1.25rem; }

        /* Stat cards */
        .stat-card {
            border-radius: 1rem;
            padding: 1.25rem 1.5rem;
            display: flex; align-items: center; gap: 1rem;
        }
        .stat-icon {
            width: 3rem; height: 3rem;
            border-radius: .75rem;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }
        .stat-label { font-size: .8rem; color: var(--gray-400); text-transform: uppercase; letter-spacing: .05em; font-weight: 600; }
        .stat-value { font-size: 1.6rem; font-weight: 700; line-height: 1.1; }
        .stat-sub   { font-size: .8rem; color: var(--gray-400); margin-top: .2rem; }

        /* Form */
        .form-label { font-size: .875rem; font-weight: 500; color: var(--gray-600); display: block; margin-bottom: .4rem; }
        .form-control {
            border: 1.5px solid var(--gray-200);
            border-radius: .6rem;
            padding: .65rem 1rem;
            font-size: 1rem;
            width: 100%;
            transition: border-color .15s;
        }
        .form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,.15); }

        .btn-primary {
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: .75rem;
            padding: .7rem 1.6rem;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s, transform .1s;
        }
        .btn-primary:hover  { background: var(--primary-dark); }
        .btn-primary:active { transform: scale(.98); }

        .toast-success {
            position: fixed; top: 1.5rem; right: 1.5rem; z-index: 9999;
            background: var(--accent-green);
            color: #fff;
            padding: .9rem 1.4rem;
            border-radius: .75rem;
            box-shadow: 0 4px 16px rgba(16,185,129,.3);
            font-weight: 500;
            display: flex; align-items: center; gap: .6rem;
            animation: slideIn .3s ease;
        }
        @keyframes slideIn { from { opacity:0; transform:translateX(2rem); } to { opacity:1; transform:none; } }

        .chart-canvas { width: 100% !important; max-height: 260px; }

        .progress-bar-wrap { background: var(--gray-100); border-radius: 999px; height: .75rem; overflow: hidden; margin-top: .4rem; }
        .progress-bar-fill { height: 100%; border-radius: 999px; transition: width .6s ease; }

        .goal-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
        .goal-row:last-child { margin-bottom: 0; }
        .goal-label { font-size: .875rem; font-weight: 500; color: var(--gray-600); }
        .goal-pct   { font-size: .85rem; font-weight: 700; }
    </style>
{% endblock %}

{% block body %}

{# ── Flash messages ── #}
{% for message in app.flashes('success') %}
    <div class="toast-success" id="toast">✅ {{ message }}</div>
{% endfor %}

{# ── Header ── #}
<div class="page-header">
    <div class="container">
        <h1>📈 My Progress</h1>
        <p>Track your weight, calories, and workout history</p>
    </div>
</div>

<div class="container" style="max-width:960px;">

    {# ── Summary stat cards ── #}
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-4">
            <div class="card stat-card">
                <div class="stat-icon" style="background:var(--primary-bg); color:var(--primary);">🔥</div>
                <div>
                    <div class="stat-label">Calories Today</div>
                    <div class="stat-value" style="color:var(--primary);">{{ caloriesConsumed ?? 0 }}</div>
                    {% if goal and goal.dailyCalories %}
                        <div class="stat-sub">Goal: {{ goal.dailyCalories }} kcal</div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card stat-card">
                <div class="stat-icon" style="background:var(--accent-green-bg); color:var(--accent-green);">💪</div>
                <div>
                    <div class="stat-label">Workouts This Week</div>
                    <div class="stat-value" style="color:var(--accent-green);">{{ workoutsThisWeek ?? 0 }}</div>
                    {% if goal and goal.weeklyWorkouts %}
                        <div class="stat-sub">Goal: {{ goal.weeklyWorkouts }} sessions</div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card stat-card">
                <div class="stat-icon" style="background:var(--accent-purple-bg); color:var(--accent-purple);">⚖️</div>
                <div>
                    <div class="stat-label">Target Weight</div>
                    <div class="stat-value" style="color:var(--accent-purple);">
                        {% if goal and goal.targetWeight %}{{ goal.targetWeight }} kg{% else %}—{% endif %}
                    </div>
                    <div class="stat-sub">Personal goal</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        {# ── Left column: charts ── #}
        <div class="col-lg-8">

            {# Weight chart #}
            <div class="card">
                <div class="card-title">⚖️ Weight History</div>
                <canvas id="weightChart" class="chart-canvas"></canvas>
                <p class="text-muted mt-2 mb-0" style="font-size:.8rem;" id="no-weight-msg" hidden>
                    No weight logs yet — add your first entry below!
                </p>
            </div>

            {# Log weight form #}
            <div class="card">
                <div class="card-title">➕ Log Today's Weight</div>
                {{ form_start(form) }}
                <div class="row g-3 align-items-end">
                    <div class="col-sm-5">
                        {{ form_label(form.weight, null, {label_attr: {class: 'form-label'}}) }}
                        {{ form_widget(form.weight, {attr: {class: 'form-control', placeholder: 'kg', step: '0.1', min: '1'}}) }}
                        {{ form_errors(form.weight) }}
                    </div>
                    <div class="col-sm-5">
                        {{ form_label(form.date, null, {label_attr: {class: 'form-label'}}) }}
                        {{ form_widget(form.date, {attr: {class: 'form-control'}}) }}
                        {{ form_errors(form.date) }}
                    </div>
                    <div class="col-sm-2">
                        <button type="submit" class="btn-primary w-100">Save</button>
                    </div>
                </div>
                {{ form_end(form) }}
            </div>

        </div>{# /left #}

        {# ── Right column: monthly goals summary ── #}
        <div class="col-lg-4">
            <div class="card">
                <div class="card-title">🏆 Monthly Goals Summary</div>

                {# Calories progress #}
                {% set calGoal = goal.dailyCalories ?? 0 %}
                {% set calPct  = calGoal > 0 ? min((caloriesConsumed ?? 0) / calGoal * 100, 100)|round : 0 %}
                <div class="goal-row">
                    <div>
                        <div class="goal-label">🔥 Daily Calories</div>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar-fill" style="width:{{ calPct }}%; background:var(--primary);"></div>
                        </div>
                    </div>
                    <div class="goal-pct ms-3" style="color:var(--primary);">{{ calPct }}%</div>
                </div>

                {# Workouts progress #}
                {% set woGoal = goal.weeklyWorkouts ?? 0 %}
                {% set woPct  = woGoal > 0 ? min((workoutsThisWeek ?? 0) / woGoal * 100, 100)|round : 0 %}
                <div class="goal-row">
                    <div style="flex:1;">
                        <div class="goal-label">💪 Weekly Workouts</div>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar-fill" style="width:{{ woPct }}%; background:var(--accent-green);"></div>
                        </div>
                    </div>
                    <div class="goal-pct ms-3" style="color:var(--accent-green);">{{ woPct }}%</div>
                </div>

                <hr style="border-color:var(--gray-100);">

                <div style="font-size:.85rem; color:var(--gray-600);">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Calorie goal</span>
                        <strong>{{ calGoal > 0 ? calGoal ~ ' kcal' : 'Not set' }}</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>Workout goal</span>
                        <strong>{{ woGoal > 0 ? woGoal ~ ' / week' : 'Not set' }}</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Target weight</span>
                        <strong>{{ goal.targetWeight ? goal.targetWeight ~ ' kg' : 'Not set' }}</strong>
                    </div>
                </div>

                <div class="mt-3 pt-3" style="border-top:1px solid var(--gray-100);">
                    <a href="{{ path('app_goals') }}" class="btn-primary" style="display:block; text-align:center; text-decoration:none; padding:.65rem;">
                        ✏️ Update Goals
                    </a>
                </div>
            </div>
        </div>

    </div>{# /row #}
</div>{# /container #}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script>
    // Auto-hide toast
    const toast = document.getElementById('toast');
    if (toast) setTimeout(() => toast.remove(), 3000);

    // Load weight chart from API
    async function loadWeightChart() {
        try {
            const res  = await fetch('{{ path('app_progress_data') }}');
            const json = await res.json();

            if (!json.labels || json.labels.length === 0) {
                document.getElementById('no-weight-msg').hidden = false;
                return;
            }

            const ctx = document.getElementById('weightChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: json.labels,
                    datasets: [{
                        label: 'Weight (kg)',
                        data: json.data,
                        borderColor: '#8B5CF6',
                        backgroundColor: 'rgba(139,92,246,.1)',
                        borderWidth: 2.5,
                        pointBackgroundColor: '#8B5CF6',
                        pointRadius: 4,
                        tension: 0.35,
                        fill: true,
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: ctx => ctx.parsed.y + ' kg'
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            grid: { color: '#F3F4F6' },
                            ticks: { callback: v => v + ' kg' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        } catch(e) {
            console.warn('Could not load weight data:', e);
            document.getElementById('no-weight-msg').hidden = false;
        }
    }

    loadWeightChart();
    </script>
{% endblock %}

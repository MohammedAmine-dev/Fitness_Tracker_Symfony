{% extends 'base.html.twig' %}

{% block title %}FitTrack | Login{% endblock %}

{% block meta_description %}Log in to your FitTrack account to access your fitness dashboard.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        <a href="{{ path('app_login') }}" class="auth-logo">
            <div class="logo-icon">FT</div>
            <div class="logo-text">Fit<span>Track</span></div>
        </a>

        <h1 class="auth-heading">Welcome back</h1>
        <p class="auth-subheading">Sign in to continue your fitness journey</p>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success" role="alert">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="alert alert-error" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form id="login-form" action="{{ path('app_login') }}" method="post">
            <div class="form-group">
                <label class="form-label" for="login-email">Email Address</label>
                <input
                    id="login-email"
                    type="email"
                    name="_username"
                    class="form-input"
                    value="{{ last_username }}"
                    placeholder="you@example.com"
                    autocomplete="email"
                    required
                    autofocus
                >
            </div>

            <div class="form-group">
                <label class="form-label" for="login-password">Password</label>
                <input
                    id="login-password"
                    type="password"
                    name="_password"
                    class="form-input"
                    placeholder="Your password"
                    autocomplete="current-password"
                    required
                >
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button id="login-submit" type="submit" class="btn btn-primary btn-full">
                Login
            </button>
        </form>

        <p class="auth-footer">
            Don't have an account?
            <a href="{{ path('app_register') }}">Register here</a>
        </p>
    </div>
</div>
{% endblock %}

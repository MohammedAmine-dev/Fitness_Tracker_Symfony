<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - FitTrack</title>
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
</head>
<body>
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="logo-icon">FT</div>
            <span class="logo-text">Fit<span>Track</span></span>
        </div>

        <h1 class="auth-heading">Welcome back</h1>
        <p class="auth-subheading">Sign in to continue your fitness journey.</p>

        {% if registered %}
            <div class="alert alert-success" role="alert">
                Account created. Please sign in.
            </div>
        {% endif %}

        {% if error %}
            <div class="alert alert-error" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" class="auth-form" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label class="form-label" for="email">Email Address</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    class="form-input"
                    value="{{ last_username }}"
                    autocomplete="email"
                    required
                >
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    class="form-input"
                    autocomplete="current-password"
                    required
                >
            </div>

            <div class="form-group form-inline">
                <label class="form-check">
                    <input type="checkbox" name="remember_me" value="on">
                    <span>Remember me</span>
                </label>
            </div>

            <button type="submit" class="btn btn-primary">Sign In</button>
        </form>

        <div class="auth-footer">
            <div class="form-divider"><span>don\'t have an account?</span></div>
            <a href="{{ path('app_register') }}" class="btn btn-secondary">Create Account</a>
        </div>
    </div>
</div>
</body>
</html>

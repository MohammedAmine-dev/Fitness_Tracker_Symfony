{% extends 'base.html.twig' %}

{% block title %}My Goals – FitTrack{% endblock %}

{% block importmap %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary:         #3B82F6;
            --primary-dark:    #2563EB;
            --primary-light:   #93C5FD;
            --primary-bg:      #EFF6FF;
            --accent-green:    #10B981;
            --accent-green-bg: #ECFDF5;
            --accent-orange:   #F59E0B;
            --accent-orange-bg:#FFFBEB;
            --accent-purple:   #8B5CF6;
            --accent-purple-bg:#F5F3FF;
            --gray-50:  #F9FAFB;
            --gray-100: #F3F4F6;
            --gray-200: #E5E7EB;
            --gray-400: #9CA3AF;
            --gray-600: #4B5563;
            --gray-700: #374151;
            --gray-800: #1F2937;
        }

        body { background: var(--gray-50); color: var(--gray-800); }

        .page-header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            padding: 2.5rem 0 2rem;
            margin-bottom: 2rem;
        }
        .page-header h1 { font-size: 2rem; font-weight: 700; margin: 0; }
        .page-header p  { opacity: .85; margin: .4rem 0 0; }

        .card {
            background: #fff;
            border-radius: 1rem;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
            padding: 1.75rem;
            margin-bottom: 1.5rem;
        }
        .card-icon {
            width: 3rem; height: 3rem;
            border-radius: .75rem;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            margin-bottom: 1rem;
        }
        .icon-weight   { background: var(--primary-bg);      color: var(--primary); }
        .icon-calories { background: var(--accent-orange-bg); color: var(--accent-orange); }
        .icon-workouts { background: var(--accent-green-bg);  color: var(--accent-green); }

        .card h5 { font-size: 1rem; font-weight: 600; color: var(--gray-700); margin-bottom: 1.25rem; }

        .form-group { margin-bottom: 1.25rem; }
        .form-label { font-size: .875rem; font-weight: 500; color: var(--gray-600); display: block; margin-bottom: .4rem; }
        .form-control {
            border: 1.5px solid var(--gray-200);
            border-radius: .6rem;
            padding: .65rem 1rem;
            font-size: 1rem;
            width: 100%;
            transition: border-color .15s;
        }
        .form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,.15); }

        .btn-primary {
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: .75rem;
            padding: .75rem 2rem;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s, transform .1s;
            width: 100%;
        }
        .btn-primary:hover  { background: var(--primary-dark); }
        .btn-primary:active { transform: scale(.98); }

        .toast-success {
            position: fixed; top: 1.5rem; right: 1.5rem; z-index: 9999;
            background: var(--accent-green);
            color: #fff;
            padding: .9rem 1.4rem;
            border-radius: .75rem;
            box-shadow: 0 4px 16px rgba(16,185,129,.3);
            font-weight: 500;
            display: flex; align-items: center; gap: .6rem;
            animation: slideIn .3s ease;
        }
        @keyframes slideIn { from { opacity:0; transform:translateX(2rem); } to { opacity:1; transform:none; } }

        .invalid-feedback { color: #EF4444; font-size: .8rem; margin-top: .3rem; display: block; }
    </style>
{% endblock %}

{% block body %}

{# ── Flash messages ── #}
{% for message in app.flashes('success') %}
    <div class="toast-success" id="toast">
        ✅ {{ message }}
    </div>
{% endfor %}

{# ── Header ── #}
<div class="page-header">
    <div class="container">
        <h1>🎯 My Goals</h1>
        <p>Set your targets and stay on track</p>
    </div>
</div>

<div class="container" style="max-width:860px;">

    {{ form_start(form, {attr: {id: 'goals-form', novalidate: 'novalidate'}}) }}

    <div class="row g-4">

        {# ── Target Weight ── #}
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-icon icon-weight">⚖️</div>
                <h5>Target Weight</h5>
                <div class="form-group">
                    {{ form_label(form.targetWeight, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.targetWeight, {attr: {class: 'form-control', placeholder: 'e.g. 70', min: '1', step: '0.1'}}) }}
                    {{ form_errors(form.targetWeight) }}
                </div>
            </div>
        </div>

        {# ── Daily Calories ── #}
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-icon icon-calories">🔥</div>
                <h5>Daily Calorie Goal</h5>
                <div class="form-group">
                    {{ form_label(form.dailyCalories, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.dailyCalories, {attr: {class: 'form-control', placeholder: 'e.g. 2000', min: '1'}}) }}
                    {{ form_errors(form.dailyCalories) }}
                </div>
            </div>
        </div>

        {# ── Weekly Workouts ── #}
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-icon icon-workouts">💪</div>
                <h5>Weekly Workouts</h5>
                <div class="form-group">
                    {{ form_label(form.weeklyWorkouts, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.weeklyWorkouts, {attr: {class: 'form-control', placeholder: 'e.g. 4', min: '0'}}) }}
                    {{ form_errors(form.weeklyWorkouts) }}
                </div>
            </div>
        </div>

    </div>{# /row #}

    <div class="card mt-2">
        <button type="submit" class="btn-primary">Save Goals</button>
    </div>

    {{ form_end(form) }}

</div>{# /container #}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    // Auto-hide toast after 3 s
    const toast = document.getElementById('toast');
    if (toast) setTimeout(() => toast.remove(), 3000);

    // Client-side validation
    document.getElementById('goals-form').addEventListener('submit', function(e) {
        let valid = true;

        ['goal_targetWeight', 'goal_dailyCalories', 'goal_weeklyWorkouts'].forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            const val = parseFloat(el.value);
            const existingErr = el.parentNode.querySelector('.invalid-feedback');
            if (existingErr) existingErr.remove();

            if (el.value !== '' && (isNaN(val) || val < 0)) {
                const err = document.createElement('span');
                err.className = 'invalid-feedback';
                err.textContent = 'Please enter a valid positive number.';
                el.parentNode.appendChild(err);
                el.style.borderColor = '#EF4444';
                valid = false;
            } else {
                el.style.borderColor = '';
            }
        });

        if (!valid) e.preventDefault();
    });
    </script>
{% endblock %}
